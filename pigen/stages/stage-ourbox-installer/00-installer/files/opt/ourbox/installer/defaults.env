# Defaults for fetching OS payloads at install time
# Users/ops can override by placing /boot/firmware/ourbox-installer.env on the installer media.

# OCI repo containing OS payload artifacts (oras-compatible)
OS_REPO="${OS_REPO:-ghcr.io/techofourown/ourbox-matchbox-os}"

# Target + channel determine the moving tag to pull when OS_REF is not set.
OS_TARGET="${OS_TARGET:-rpi}"
OS_CHANNEL="${OS_CHANNEL:-stable}"

# Optional catalog artifact (small TSV) for interactive selection.
OS_CATALOG_ENABLED="${OS_CATALOG_ENABLED:-1}"
OS_CATALOG_TAG="${OS_CATALOG_TAG:-${OS_TARGET}-catalog}"

# Artifact type used when pushing OS payloads via ORAS.
OS_ARTIFACT_TYPE="${OS_ARTIFACT_TYPE:-application/vnd.ourbox.matchbox.os-image.v1}"

# ORAS version to bootstrap on the installer if missing.
OS_ORAS_VERSION="${OS_ORAS_VERSION:-1.3.0}"

# Optional registry auth (if your repo is private)
OS_REGISTRY_USERNAME="${OS_REGISTRY_USERNAME:-}"
OS_REGISTRY_PASSWORD="${OS_REGISTRY_PASSWORD:-}"
